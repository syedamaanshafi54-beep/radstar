rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'itsmeabdulk@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- FIX: Allow admins to list root collections ---
    match /{path=**} {
      allow list: if isAdmin();
    }

    // --- ADMIN OVERRIDE: FULL ACCESS ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Allow admins to list subcollections explicitly
    match /users/{userId} {
      allow list: if isAdmin();
    }
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }

    // PUBLIC COLLECTIONS
    match /products/{productId} {
      allow read: if true;
    }

    match /site-config/{configId} {
      allow read: if true;
    }

    // PUBLIC CREATION
    match /partners/{partnerId} {
      allow create: if true;
    }

    // USER PRIVATE DATA
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
