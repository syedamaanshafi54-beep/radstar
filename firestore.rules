
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // In a real app, this would check a custom claim: request.auth.token.admin == true;
      // Using email for demonstration purposes.
      return request.auth != null && request.auth.token.email == 'itsmeabdulk@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // --- ADMIN OVERRIDE: FULL ACCESS ---
    // The admin has complete read/write access to all data.
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Allow admins to list orders across all users for the admin panel.
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }
    
    // --- USER-SPECIFIC RULES ---
    // These rules apply if the user is NOT an admin.
    
    // PUBLIC COLLECTIONS
    match /products/{productId} {
      allow read: if true;
    }

    match /site-config/{configId} {
      allow read: if true;
    }
    
    // PARTNER SUBMISSIONS (allow anyone to create)
    match /partners/{partnerId} {
      allow create: if true;
    }
    
    // USER-SPECIFIC DATA (only owner can access if not admin)
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
