
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // In a real app, this would check a custom claim: request.auth.token.admin == true;
      // Using email for demonstration purposes.
      return request.auth != null && request.auth.token.email == 'itsmeabdulk@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // PUBLIC COLLECTIONS
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site-config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // PARTNER SUBMISSIONS
    match /partners/{partnerId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // USER-OWNED DATA & ADMIN ACCESS
    // Admins can read/write any user's data for management purposes.
    // Users can only read/write their own data.
    match /users/{userId} {
      allow get, write: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin(); // Only admins can delete user documents

      // Subcollections
      match /customers/{customerId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
          
        match /orderItems/{orderItemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
     
    // COLLECTION-LEVEL RULES FOR LISTING (CRITICAL FOR ADMIN PANEL)
    // Allow admins to list all documents in the 'users' collection.
    match /users/{userId} {
      allow list: if isAdmin();
    }
     
    // COLLECTION GROUP RULES FOR LISTING (CRITICAL FOR ADMIN PANEL)
    // Allow admins to list all orders across all users for the admin panel.
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }
  }
}
