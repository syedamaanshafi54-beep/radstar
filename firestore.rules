
/**
 * @fileoverview Firestore Security Rules for the Asli Talbina e-commerce application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for private data (customers, orders, addresses)
 * and allows public read access to product information. Authorization Independence is achieved through
 * denormalization, embedding the customerId within the order documents to avoid costly `get()` calls in rules.
 * Structural Segregation ensures data with similar security postures are grouped together.
 *
 * Data Structure:
 * - /products/{productId}: Publicly readable product information.
 * - /site-config/{configId}: Publicly readable site configuration data.
 * - /users/{userId}: Private user data, accessible only by admins for listing.
 * - /users/{userId}/customers/{customerId}: Private customer data, accessible only to the owner.
 * - /users/{userId}/orders/{orderId}: Private order data, accessible only to the owner.
 * - /users/{userId}/orders/{orderId}/orderItems/{orderItemId}: Private order item data, accessible only to the owner.
 * - /users/{userId}/addresses/{addressId}: Private address data, accessible only to the owner.
 * - /partners/{partnerId}: Partner registration submissions.
 *
 * Key Security Decisions:
 * - Products and site configuration are publicly readable but not writable by clients.
 * - Users can only access their own customer, order, and address information.
 * - User listing is disallowed for non-admins.
 * - Data validation is minimized in this prototyping phase to focus on authorization.
 *
 * Denormalization for Authorization:
 * - Orders contain a `customerId` field matching the user's UID to ensure Authorization Independence.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @example isSignedIn() == true if request.auth != null
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user has an 'admin' role in their custom claims.
     * @return {bool} True if the user is an admin, false otherwise.
     */
    function isAdmin() {
      // In a real app, you would check a custom claim: return request.auth.token.admin == true;
      // For this project, we can check a specific known admin email for demonstration.
      return request.auth != null 
         && request.auth.token.email == 'itsmeabdulk@gmail.com';
    }

    /**
     * @description Checks if the authenticated user is the owner of the document.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @example isOwner('user123') == (request.auth.uid == 'user123')
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     *              Additionally, validates that the document exists to prevent modification of non-existent data.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @example isExistingOwner('user123') == (request.auth.uid == 'user123' && resource != null)
     * @return {bool} True if the user is the owner and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * @description Rules for the /partners collection. Allows any user to submit a registration.
     * @path /partners/{partnerId}
     * @allow (create) - Any user (authenticated or not) can create a partner registration.
     * @allow (read, update, delete) - Only admins can manage registrations.
     */
    match /partners/{partnerId} {
        allow create: if true;
        allow read, list, update, delete: if isAdmin();
    }

    /**
     * @description Rules for the /products collection. Products are publicly readable.
     * @path /products/{productId}
     * @allow (get, list) - Any user can read product information.
     * @deny (create, update, delete) - No user can create, update, or delete product information through the client; only backend services can.
     * @principle Allows public read access to product information while restricting write access.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for the /site-config collection. Site-wide configuration is publicly readable.
     * @path /site-config/{configId}
     * @allow (get, list) - Any user can read site configuration.
     * @deny (create, update, delete) - Configuration is managed by backend/admin only.
     * @principle Allows public read access to non-sensitive site configuration.
     */
    match /site-config/{configId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    /**
     * @description Rules for the /users collection and its subcollections.
     */
    match /users/{userId} {
      // Admins and the document owner can read a specific user profile.
      allow get: if isAdmin() || isOwner(userId);
      
      // Users can create their own document. Admins can create user docs too.
      allow create: if isOwner(userId) || isAdmin();

      // Users can only update their own document. Admins can update any.
      allow update: if isOwner(userId) || isAdmin();

      // Only admins can delete users.
      allow delete: if isAdmin();
      
      // Subcollections for a specific user
      match /customers/{customerId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.id == userId && request.resource.data.id == customerId;
        allow update: if (isExistingOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
      
      match /orders/{orderId} {
          allow read, write: if isOwner(userId);
      }

      match /orders/{orderId}/orderItems/{orderItemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /addresses/{addressId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.id == addressId;
        allow update: if (isExistingOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }
     
    // Rule for LISTING the 'users' collection. 
    // Allow any user with the admin email to list all users.
    match /users {
      allow list: if isAdmin();
    }
     
    // Rule for the 'orders' collection group. Admins can list all orders across all users.
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }
  }
}
