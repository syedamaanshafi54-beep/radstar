
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // In a real app, this would check a custom claim: request.auth.token.admin == true;
      // Using email for demonstration purposes.
      return request.auth != null && request.auth.token.email == 'itsmeabdulk@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // PUBLIC COLLECTIONS
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site-config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // PARTNER SUBMISSIONS
    match /partners/{partnerId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // USER-SPECIFIC DATA ACCESS (for single document reads/writes)
    // Rules for a user accessing their OWN data.
    match /users/{userId} {
      allow get, write: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /customers/{customerId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
          
        match /orderItems/{orderItemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
     
    // --- ADMIN LISTING RULES (for collection-wide queries) ---
    
    // Rule to allow admins to LIST all documents in the 'users' collection.
    match /users/{userId} {
      allow list: if isAdmin();
    }
    
    // Rule to allow admins to LIST all documents in the 'orders' collection group.
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }
  }
}
