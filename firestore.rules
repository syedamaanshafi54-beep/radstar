
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'itsmeabdulk@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // PUBLIC COLLECTIONS
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site-config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // PARTNER SUBMISSIONS
    match /partners/{partnerId} {
      allow create: if true;
      allow read, list, update, delete: if isAdmin();
    }

    // USER-OWNED DATA
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Subcollections
      match /customers/{customerId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /orders/{orderId} {
        allow read, write: if isOwner(userId);
          
        match /orderItems/{orderItemId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
     
    // COLLECTION-LEVEL RULES FOR LISTING
    match /users/{userId} {
      // Admins can list users. Note: This rule is intentionally broad for the admin panel.
      // In a more complex app, you might restrict the fields returned.
      allow list: if isAdmin();
    }
     
    // COLLECTION GROUP RULES
    match /{path=**}/orders/{orderId} {
      // Admins can list all orders across all users.
      allow list: if isAdmin();
    }
  }
}
